# =============================================
# ShootSix Studio — Environment Variables
# =============================================
# Copy file này thành .env.local và điền API keys

# --- Google Gemini (miễn phí tại aistudio.google.com) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI (dùng làm fallback, cần tài khoản paid) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Cấu hình app ---
# Chọn AI provider mặc định: gemini | openai
AI_PROVIDER=gemini

# Kích thước file tối đa (MB)
MAX_FILE_SIZE_MB=10

# Public vars (hiển thị ở frontend)
NEXT_PUBLIC_APP_NAME=ShootSix Studio
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
