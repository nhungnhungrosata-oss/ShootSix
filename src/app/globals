@import "tailwindcss";

@keyframes slide-up {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-slide-up {
  animation: slide-up 0.3s ease-out;
}

/* Safe area for notched phones */
body {
  padding-bottom: env(safe-area-inset-bottom);
}
