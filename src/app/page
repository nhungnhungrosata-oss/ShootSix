"use client";

import { useState, useCallback } from "react";
import UploadZone from "@/components/UploadZone";
import ResultGrid from "@/components/ResultGrid";
import DownloadAll from "@/components/DownloadAll";
import InstallBanner from "@/components/InstallBanner";
import { useGenerate } from "@/hooks/useGenerate";

export default function Home() {
  const [uploadedFile, setUploadedFile] = useState<File | null>(null);
  const [uploadedPreview, setUploadedPreview] = useState<string | null>(null);
  const [provider, setProvider] = useState<"gemini" | "openai">("gemini");

  const {
    results,
    isGenerating,
    generate,
    reset,
    retryShot,
    doneCount,
    errorCount,
    progress,
    allDone,
  } = useGenerate();

  const handleUpload = useCallback((file: File) => {
    setUploadedFile(file);
    if (uploadedPreview) URL.revokeObjectURL(uploadedPreview);
    const url = URL.createObjectURL(file);
    setUploadedPreview(url);
    reset();
  }, [uploadedPreview, reset]);

  const handleGenerate = () => {
    if (!uploadedFile) return;
    generate(uploadedFile, provider);
  };

  const handleRetry = (shotId: number) => {
    if (!uploadedFile) return;
    retryShot(shotId, uploadedFile, provider);
  };

  const handleReset = () => {
    if (uploadedPreview) URL.revokeObjectURL(uploadedPreview);
    setUploadedFile(null);
    setUploadedPreview(null);
    reset();
  };

  const hasResults = results.some((r) => r.status !== "idle");

  return (
    <main className="min-h-screen bg-gray-950 text-white pb-24">
      <InstallBanner />

      {/* Header */}
      <header className="sticky top-0 z-40 bg-gray-950/90 backdrop-blur border-b border-gray-800/50 px-4 py-3 flex items-center justify-between">
        <div className="flex items-center gap-2.5">
          <div className="w-8 h-8 bg-gradient-to-br from-orange-400 to-pink-600 rounded-lg flex items-center justify-center text-xs font-bold shadow-lg">
            S6
          </div>
          <div>
            <span className="font-semibold text-base leading-none">ShootSix Studio</span>
            <p className="text-xs text-gray-500 leading-none mt-0.5">AI Product Photography</p>
          </div>
        </div>

        {/* Provider toggle */}
        <div className="flex items-center gap-1 bg-gray-900 border border-gray-800 rounded-xl p-1">
          <button
            onClick={() => setProvider("gemini")}
            className={`px-2.5 py-1 rounded-lg text-xs font-medium transition-all ${
              provider === "gemini"
                ? "bg-gradient-to-r from-blue-600 to-blue-500 text-white shadow"
                : "text-gray-400 hover:text-gray-300"
            }`}
          >
            Gemini
          </button>
          <button
            onClick={() => setProvider("openai")}
            className={`px-2.5 py-1 rounded-lg text-xs font-medium transition-all ${
              provider === "openai"
                ? "bg-gradient-to-r from-green-600 to-green-500 text-white shadow"
                : "text-gray-400 hover:text-gray-300"
            }`}
          >
            GPT
          </button>
        </div>
      </header>

      <div className="max-w-2xl mx-auto px-4 py-8 space-y-8">

        {/* Hero */}
        {!hasResults && (
          <div className="text-center space-y-2 pt-4">
            <h1 className="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-orange-400 to-pink-500 bg-clip-text text-transparent">
              6 ảnh sản phẩm chuẩn TMĐT
            </h1>
            <p className="text-sm text-gray-400">
              Upload 1 ảnh → AI tạo 6 góc chuyên nghiệp trong &lt; 1 phút

            </p>
          </div>
        )}

        {/* Upload zone */}
        <UploadZone
          onUpload={handleUpload}
          preview={uploadedPreview}
          disabled={isGenerating}
        />

        {/* CTA + Progress */}
        {uploadedFile && (
          <div className="flex flex-col items-center gap-4">
            {!isGenerating && !allDone && (
              <button
                onClick={handleGenerate}
                className="px-8 py-4 bg-gradient-to-r from-orange-500 to-pink-600 rounded-2xl font-semibold text-base hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-orange-500/20"
              >
                ✨ Tạo 6 ảnh sản phẩm
              </button>
            )}

            {isGenerating && (
              <div className="w-full space-y-3">
                <div className="flex justify-between text-xs text-gray-400">
                  <span>Đang xử lý {provider === "gemini" ? "Gemini AI" : "GPT Image"}...</span>
                  <span className="font-medium text-orange-400">{doneCount}/6 ảnh</span>
                </div>
                <div className="w-full bg-gray-800 rounded-full h-2 overflow-hidden">
                  <div
                    className="bg-gradient-to-r from-orange-500 to-pink-600 h-full rounded-full transition-all duration-700"
                    style={{ width: `${progress}%` }}
                  />
                </div>
              </div>
            )}

            {allDone && (
              <div className="text-center space-y-1">
                <p className="text-green-400 font-medium text-sm">
                  ✅ Hoàn thành! {doneCount} ảnh đã sẵn sàng
                </p>
                {errorCount > 0 && (
                  <p className="text-red-400 text-xs">{errorCount} ảnh gặp lỗi — nhấn &quot;Thử lại&quot;</p>
                )}
              </div>
            )}
          </div>
        )}

        {/* Result grid */}
        <ResultGrid
          results={results}
          uploadedFile={uploadedFile}
          onRetry={handleRetry}
        />

        {/* Download all */}
        {doneCount > 0 && (
          <DownloadAll results={results} />
        )}

        {/* Reset button */}
        {(hasResults || uploadedFile) && !isGenerating && (
          <div className="flex justify-center">
            <button
              onClick={handleReset}
              className="text-xs text-gray-600 hover:text-gray-400 transition-colors"
            >
              ↺ Bắt đầu lại
            </button>
          </div>
        )}

        {/* Info cards */}
        {!hasResults && !uploadedFile && (
          <div className="grid grid-cols-3 gap-3 pt-4">
            {[
              { icon: "📸", label: "1 ảnh đầu vào", sub: "JPG, PNG, WEBP" },
              { icon: "✨", label: "AI xử lý", sub: "Gemini / GPT" },
              { icon: "🖼", label: "6 ảnh vuông", sub: "1024×1024px" },
            ].map((item) => (
              <div
                key={item.label}
                className="bg-gray-900/50 border border-gray-800 rounded-2xl p-4 text-center"
              >
                <div className="text-2xl mb-2">{item.icon}</div>
                <p className="text-xs font-medium text-gray-300">{item.label}</p>
                <p className="text-xs text-gray-600 mt-0.5">{item.sub}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </main>
  );
}
